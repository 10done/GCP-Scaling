# Copy to cloud.env (gitignored) and fill in. Do not commit secrets.
# Example for GCP:
# export GCP_PROJECT=my-project
# export GCP_ZONE=us-central1-a
# export GCP_MIG_NAME=my-mig
# export GCP_MAX_SIZE=5
#
# Then run:
#   source config/cloud.env
#   export SCALE_SCRIPT="$(pwd)/scale-out-gcp.sh"
#   python monitor.py
